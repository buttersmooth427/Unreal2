	}
	Lighting.Specular *= ComputeEnergyConservation(EnergyTermsCoat);



	AreaLight.SphereSinAlpha = SphereSinAlpha;
	Alpha = Pow2(GBuffer.Roughness);







	float FresnelCoeff = 1.0 - F;

