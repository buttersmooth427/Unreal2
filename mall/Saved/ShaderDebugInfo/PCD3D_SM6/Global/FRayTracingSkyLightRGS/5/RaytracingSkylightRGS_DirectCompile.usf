uint2 GetPixelCoord(uint2 DispatchThreadId, uint UpscaleFactor)
{
	uint UpscaleFactorPow2 = UpscaleFactor * UpscaleFactor;


	uint SubPixelId = View_StateFrameIndex & (UpscaleFactorPow2 - 1);

