float  F0ToMicroOcclusion(float F0)   { return saturate(50.0 * F0); }
float3 F0ToMicroOcclusion(float3 F0)  { return saturate(50.0 * F0); }
float F0RGBToMicroOcclusion(float3 F0)
{
	return F0ToMicroOcclusion(F0RGBToF0(F0));
